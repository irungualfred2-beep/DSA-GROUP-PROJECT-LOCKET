
import { LocketPhoto, Friend, PhotoComment } from '../types';

const PHOTOS_KEY = 'locket_photos_data_v2';
const FRIENDS_KEY = 'locket_friends_data_v2';

export const storageService = {
  getPhotos: (): LocketPhoto[] => {
    const data = localStorage.getItem(PHOTOS_KEY);
    return data ? JSON.parse(data) : [];
  },

  savePhoto: (photo: LocketPhoto) => {
    const photos = storageService.getPhotos();
    localStorage.setItem(PHOTOS_KEY, JSON.stringify([photo, ...photos]));
  },

  updatePhoto: (id: string, updates: Partial<LocketPhoto>) => {
    const photos = storageService.getPhotos();
    const updatedPhotos = photos.map(p => p.id === id ? { ...p, ...updates } : p);
    localStorage.setItem(PHOTOS_KEY, JSON.stringify(updatedPhotos));
  },

  addComment: (photoId: string, comment: PhotoComment) => {
    const photos = storageService.getPhotos();
    const updatedPhotos = photos.map(p => {
      if (p.id === photoId) {
        return {
          ...p,
          comments: [...(p.comments || []), comment]
        };
      }
      return p;
    });
    localStorage.setItem(PHOTOS_KEY, JSON.stringify(updatedPhotos));
  },

  getFriends: (): Friend[] => {
    const data = localStorage.getItem(FRIENDS_KEY);
    if (!data) {
      const initialFriends: Friend[] = [
        { id: '1', name: 'Alex', status: 'online', lastActive: Date.now(), avatar: 'https://picsum.photos/seed/alex/200' },
        { id: '2', name: 'Jordan', status: 'offline', lastActive: Date.now() - 3600000, avatar: 'https://picsum.photos/seed/jordan/200' },
        { id: '3', name: 'Sarah', status: 'online', lastActive: Date.now(), avatar: 'https://picsum.photos/seed/sarah/200' }
      ];
      localStorage.setItem(FRIENDS_KEY, JSON.stringify(initialFriends));
      return initialFriends;
    }
    return JSON.parse(data);
  },

  saveFriends: (friends: Friend[]) => {
    localStorage.setItem(FRIENDS_KEY, JSON.stringify(friends));
  },

  addFriend: (name: string) => {
    const friends = storageService.getFriends();
    const newFriend: Friend = {
      id: Math.random().toString(36).substr(2, 9),
      name,
      status: 'offline',
      lastActive: Date.now(),
      avatar: `https://picsum.photos/seed/${name}/200`
    };
    const updated = [...friends, newFriend];
    localStorage.setItem(FRIENDS_KEY, JSON.stringify(updated));
    return newFriend;
  },

  deletePhoto: (id: string) => {
    const photos = storageService.getPhotos();
    localStorage.setItem(PHOTOS_KEY, JSON.stringify(photos.filter(p => p.id !== id)));
  }
};
